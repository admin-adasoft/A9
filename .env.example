# ==============================================================================
# NAM-WH HMI Environment Configuration
# ==============================================================================
# Copy this file to .env and update with your actual values
# Priority: Environment Variables > .env file > Hardcoded Defaults in settings.py

# ==============================================================================
# Application Settings
# ==============================================================================
APP_NAME=NAM-HW HMI
APP_VERSION=2.0.0
MODEL=NAM-HW
DEBUG_MODE=false
MOCK_PLC=false
SHOW_DEBUG_INFO=false

# ==============================================================================
# Database Settings
# ==============================================================================
DATABASE_PATH=data/nam_wh.db
DATABASE_BACKUP_DIR=data/backups
DATABASE_ECHO=false
DATABASE_BACKUP_ENABLED=true

# ==============================================================================
# PLC Connection (Modbus TCP)
# ==============================================================================
# Main connection settings
PLC_HOST=192.168.0.2
PLC_PORT=502
# Fallback path for direct file edit when nmcli is unavailable
PI_NETWORK_INTERFACES_FILE=/etc/network/interfaces
PLC_TIMEOUT=3.0
PLC_RETRY_COUNT=3
PLC_RETRY_DELAY=1.0

# Modbus protocol
MODBUS_UNIT_ID=1
# String bytes in one MI word: little (low-byte first) for Unitronics
MODBUS_BYTE_ORDER=little
MODBUS_WORD_ORDER=big

# Health check
HEALTH_CHECK_INTERVAL=5.0
MAX_CONSECUTIVE_FAILURES=5

# Optimization
ENABLE_BATCH_READ=true
MAX_BATCH_SIZE=100
ENABLE_CACHE=true
CACHE_TTL=0.25

# Stats & monitoring
LOG_COMMUNICATION_STATS=true
STATS_LOG_INTERVAL=60

# ==============================================================================
# UI Settings
# ==============================================================================
UI_FRAMEWORK=PySide6
SCREEN_WIDTH=1024
SCREEN_HEIGHT=600
FULLSCREEN=true
HIDE_CURSOR=false
IDLE_SCREEN_BLANK_ENABLED=false
IDLE_SCREEN_BLANK_TIMEOUT_SECONDS=300

# ==============================================================================
# Second Display (Sub-Screen for secondary monitor / USB touchscreen)
# ==============================================================================
SCREEN2_ENABLED=false
SCREEN2_DISPLAY_INDEX=1
SCREEN2_WIDTH=1024
SCREEN2_HEIGHT=600

# ==============================================================================
# Language Settings
# ==============================================================================
DEFAULT_LANGUAGE=th_TH
SUPPORTED_LANGUAGES=th_TH,en_GB

# ==============================================================================
# Timezone Settings
# ==============================================================================
# IANA timezone name — used for all local-time display in the HMI
# Common values: Asia/Bangkok, Asia/Singapore, UTC
APP_TIMEZONE=Asia/Bangkok

# ==============================================================================
# Session Management
# ==============================================================================
SESSION_TIMEOUT=900
AUTO_LOGOUT_ENABLED=true
INACTIVITY_CHECK_INTERVAL=60

# ==============================================================================
# Logging Settings
# ==============================================================================
LOG_LEVEL=INFO
LOG_FILE=data/logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==============================================================================
# Performance Settings (Polling Intervals in seconds)
# ==============================================================================
PLC_POLLING_INTERVAL=0.1
DATA_LOGGING_INTERVAL=5
ALARM_POLLING_INTERVAL=0.5
UI_UPDATE_INTERVAL=0.1

# ==============================================================================
# Button Settings (PM Designer V2 Momentary ON behavior)
# ==============================================================================
# Minimal Pulse Width in seconds (default matches PM Designer V2: 0.05s = 50ms)
BUTTON_PULSE_WIDTH=0.05

# ==============================================================================
# Reconnection Settings
# ==============================================================================
# Maximum backoff delay for exponential retry (seconds)
RECONNECT_MAX_BACKOFF=60.0
# Sleep duration on monitoring loop error (seconds)
RECONNECT_ERROR_SLEEP=1.0

# ==============================================================================
# Data Format Settings (PM Designer V2 specifications)
# ==============================================================================
# Program/Basket name length in words (registers), 1 word = 2 characters
PROGRAM_NAME_LENGTH=14
BASKET_NAME_LENGTH=10
# Total number of screens in HMI
MAX_SCREEN_NUMBER=30
# Temperature validation range (°C)
TEMP_VALIDATION_MIN=0
TEMP_VALIDATION_MAX=200

# ==============================================================================
# Security Settings
# ==============================================================================
PASSWORD_MIN_LENGTH=4
ENABLE_AUDIT_LOG=true
# Permission enforcement (false = bypass all permission checks for testing/development)
ENABLE_PERMISSION=false

# ==============================================================================
# RFID Reader Settings
# ==============================================================================
RFID_ENABLED=true
RFID_PORT=/dev/ttyUSB0
RFID_BAUD_RATE=9600
RFID_TIMEOUT=5
RFID_AUTO_LOGOUT_ON_REMOVAL=true

# ==============================================================================
# Alarm Settings
# ==============================================================================
ALARM_AUDIO_ENABLED=true
ALARM_CRITICAL_BEEPS=3
ALARM_WARNING_BEEPS=1
ALARM_WARNING_AUTO_DISMISS=10

# ==============================================================================
# Trend Logging Settings
# ==============================================================================
# In-memory ring buffer capacity + DB reload limit (samples @ 1 sample/second)
# 7200 = 2 hours, 3600 = 1 hour, 10800 = 3 hours
TREND_MAX_SAMPLES=7200

# ==============================================================================
# Data Retention (days)
# ==============================================================================
TREND_DATA_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=90
ALARM_HISTORY_RETENTION_DAYS=365

# ==============================================================================
# IoT Integration (Optional - Phase 2/3)
# ==============================================================================
IOT_ENABLED=false
THINGSBOARD_HOST=thingsboard.cloud
THINGSBOARD_PORT=1883
DEVICE_ACCESS_TOKEN=YOUR_DEVICE_ACCESS_TOKEN_HERE
TELEMETRY_INTERVAL=10

# ==============================================================================
# Notes
# ==============================================================================
# - Boolean values: use 'true' or 'false' (lowercase)
# - Numbers: no quotes needed
# - Strings with spaces: no quotes needed
# - File paths: relative to project root or absolute paths
# - For production: Set DEBUG_MODE=false, MOCK_PLC=false, HIDE_CURSOR=true
