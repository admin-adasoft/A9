   <string notr="true">QWidget#DoorPanelHorizonWidget {
    background-color: transparent;
}

/* Door buttons (square gray) */
#obtn_door_open,
#obtn_door_close {
    background-color: #D9D9D9;
    border: none;
    border-radius: 10px;
}
#obtn_door_open:hover,
#obtn_door_close:hover {
    background-color: #E5E5E5;
}

#obtn_door_open:pressed,
#obtn_door_close:pressed {
    background-color: #FFA93F;
}
* {
    font-family: 'Poppins', 'Noto Sans Thai';
}
</string>
