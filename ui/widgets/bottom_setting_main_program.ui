   <string notr="true">
/* ===== RANGE TAB BUTTONS ===== */
QPushButton#obtn_range_1,
QPushButton#obtn_range_2,
QPushButton#obtn_range_3 {
    
    border-radius: 15px;
    font-family: 'Tahoma';
    font-weight: bold;
    font-size: 13pt;
    background-color: #ffffff;
    border: 1px solid #000000;
    color: #000000;
}
/* Range tab: Active (selected) */
QPushButton#obtn_range_1[active=&quot;true&quot;],
QPushButton#obtn_range_2[active=&quot;true&quot;],
QPushButton#obtn_range_3[active=&quot;true&quot;] {
    background-color: #003057;
    border: 2px solid #003057;
    border-bottom: 3px solid #001a33;
    color: #ffffff;
}

/* ===== PROGRAM LIST BUTTON ===== */
QPushButton#obtn_program_list {
    border-radius: 15px;
    font-family: 'Poppins', 'Noto Sans Thai';
    font-weight: bold;
    font-size: 13pt;
    background-color: #003057;
    border: none;
    color: #ffffff;
}
QPushButton#obtn_program_list:pressed {
    background-color: #194c7a;
}

/* ===== ACTION LEFT BUTTON (ยกเลิก / เดรน / ล้าง) ===== */
/* Default: ยกเลิก — Red */
QPushButton#obtn_action_left {
    
    border-radius: 15px;
    font-family: 'Tahoma', 'Noto Sans Thai';
    font-weight: bold;
    font-size: 13pt;
    border: none;
    color: #ffffff;
    background-color: #FF0000;
}
QPushButton#obtn_action_left:pressed {
    background-color: #CC0000;
}
/* mode_set_wash: เดรน — Orange */
QPushButton#obtn_action_left[mode=&quot;set_wash&quot;] {
    background-color: #FF8C00;
}
QPushButton#obtn_action_left[mode=&quot;set_wash&quot;]:pressed {
    background-color: #E67E00;
}
/* mode_set_drain: ล้าง — Cyan */
QPushButton#obtn_action_left[mode=&quot;set_drain&quot;] {
    background-color: #00BCD4;
}
QPushButton#obtn_action_left[mode=&quot;set_drain&quot;]:pressed {
    background-color: #0097A7;
}

/* ===== ACTION RIGHT BUTTON (ยืนยัน / บันทึก) ===== */
QPushButton#obtn_action_right {
    
    border-radius: 15px;
    font-family: 'Tahoma', 'Noto Sans Thai';
    font-weight: bold;
    font-size: 13pt;
    border: none;
    color: #ffffff;
    background-color: #27AE60;
}
QPushButton#obtn_action_right:pressed {
    background-color: #1E8449;
}
   </string>
