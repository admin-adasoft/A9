  <property name="styleSheet">
   <string notr="true">/* 
DESIGN LOGIC: SIDEBAR MENU ANIMATION
- ofrm_selection_indicator: A floating QFrame used as an animated selection background.
- Logic: In Python, use QPropertyAnimation on 'geometry' property to move this frame.
- Animation: Target the geometry of the clicked QPushButton.
- Styling: QPushButton:checked is transparent to reveal this indicator behind it.
- Blinking: Use status='alert_on'/'alert_off' with a QTimer for the bell icon.
*/

SidebarMenuWidget, QWidget#SidebarMenuWidget, QWidget#sidebar_menu_widget {
	background-color: #FFFFFF;
	border-top-right-radius: 70px;
	border-bottom-right-radius: 70px;
	border: 7px solid #003057;
}
QPushButton {
	background-color: transparent;
	border: none;
	color: white;
    padding: 10px;
    border-radius: 10px;
}
QPushButton:hover {
	background-color: rgba(255, 255, 255, 0.2);
}
QPushButton:checked {
	background-color: transparent;
}

QFrame#ofrm_selection_indicator {
	background-color: rgba(255, 255, 255, 0.3);
    border-radius: 15px;
}

/* --- Status: Alert (Bell Only - Blinking support) --- */
/* Icon is managed by Python setIcon() — no qproperty-icon here */
QPushButton#obtn_alarm_side[status="alert"],
QPushButton#obtn_alarm_side[status="alert_on"],
QPushButton#obtn_alarm_side[status="alert_off"] {
    background-color: rgba(243, 53, 53, 0.0);
    border: none;
}
QPushButton#obtn_alarm_side[status="alert"]:hover,
QPushButton#obtn_alarm_side[status="alert_on"]:hover,
QPushButton#obtn_alarm_side[status="alert_off"]:hover {
    background-color: rgba(243, 53, 53, 0);
}

/* --- Status: Warning (General) --- */
QPushButton[status="warning"] {
    background-color: rgba(255, 178, 0, 0.4);
    border: 2px solid #FFB200;
}
QPushButton[status="warning"]:hover {
    background-color: rgba(255, 178, 0, 0.6);
}

* { font-family: 'Poppins', 'Noto Sans Thai'; }</string>
