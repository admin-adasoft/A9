  <property name="styleSheet">
   <string notr="true">QMainWindow#Screen01Home {
    background-color: rgb(255, 255, 255);
    font-family: 'Poppins', 'Noto Sans Thai';
}

/* Program selection cards */
QToolButton#obtn_program_1_standard,
QToolButton#obtn_program_2_short,
QToolButton#obtn_program_3_intensive,
QToolButton#obtn_program_4_rapid {
    background-color: white;
    border: 5px solid #003057;
    border-radius: 20px;
    color: black;
    font-family: &quot;Poppins&quot;, &quot;Noto Sans Thai&quot;;
    font-size: 20px;
    font-weight: bold;
    text-align: bottom;
    padding-top: 10px;
    padding-bottom: 20px;
}
QToolButton#obtn_program_1_standard:hover,
QToolButton#obtn_program_2_short:hover,
QToolButton#obtn_program_3_intensive:hover,
QToolButton#obtn_program_4_rapid:hover {
    background-color: #F0F4F8;
    border-color: #004B93;
}

QToolButton#obtn_program_1_standard:pressed,
QToolButton#obtn_program_2_short:pressed,
QToolButton#obtn_program_3_intensive:pressed,
QToolButton#obtn_program_4_rapid:pressed {
    background-color: #e0e0e0;
}

/* Navigation button (circular) */
QToolButton#obtn_next_program {
    background-color: #004B93;
    border: none;
    border-radius: 35px;
    color: white;
}
QToolButton#obtn_next_program:hover {
    background-color: #005BB0;
}

QToolButton#obtn_next_program:pressed {
    background-color: #003A72;
}


QLabel#olbl_program {
    color: #003057;
    font-size: 56px;
    font-weight: bold;
    font-family: 'Poppins', 'Noto Sans Thai';
}

QLabel#olbl_version {
    color: #000000;
    font-family: 'Poppins', 'Noto Sans Thai';
}
</string>
