  <property name="styleSheet">
   <string notr="true">
        #ofrm_central { background-color: #ffffff; }

        QLineEdit#otxt_search {
            background-color: #ffffff;
            border: 3px solid #003057;
            border-radius: 20px;
            padding: 6px 20px;
            font-family: 'Poppins', 'Noto Sans Thai';
            font-size: 16px;
            color: #333333;
        }
        QLineEdit#otxt_search:focus {
            border: 3px solid #0099cc;
        }

        /* Delete button logic: turns red when active="true" is set in Python code (row selected) */
        QPushButton#obtn_delete {
            background-color: #e0e0e0;
            border: none;
            border-radius: 15px;
            color: #333333;
            font-family: 'Poppins';
            font-weight: bold;
            font-size: 24px;
        }
        QPushButton#obtn_delete[active="true"] {
            background-color: #E74C3C; /* Critical Red */
            color: #ffffff;
        }
        QPushButton#obtn_delete:hover {
            background-color: #eeeeee;
        }
        QPushButton#obtn_delete[active="true"]:hover {
            background-color: #ff5252;
        }
        QPushButton#obtn_delete:pressed {
            background-color: #bdbdbd;
        }
        QPushButton#obtn_delete[active="true"]:pressed {
            background-color: #c62828;
        }
        QPushButton#obtn_delete:disabled {
            background-color: #f5f5f5;
            color: #bdbdbd;
        }

        QPushButton#obtn_add {
            background-color: #27AE60; /* Success Green */
            border: none;
            border-radius: 15px;
            color: #ffffff;
            font-family: 'Poppins';
            font-weight: bold;
            font-size: 24px;
        }
        QPushButton#obtn_add:hover {
            background-color: #2ECC71;
        }
        QPushButton#obtn_add:pressed {
            background-color: #1E8449;
        }

        QPushButton#obtn_view {
            background-color: #e0e0e0;
            border: none;
            border-radius: 15px;
            color: #333333;
            font-family: 'Poppins', 'Noto Sans Thai';
            font-weight: bold;
            font-size: 16px;
        }
        QPushButton#obtn_view[active="true"] {
            background-color: #003057;
            color: #ffffff;
        }
        QPushButton#obtn_view:hover {
            background-color: #eeeeee;
        }
        QPushButton#obtn_view[active="true"]:hover {
            background-color: #004B93;
        }
        QPushButton#obtn_view:pressed {
            background-color: #bdbdbd;
        }
        QPushButton#obtn_view[active="true"]:pressed {
            background-color: #002040;
        }
        QPushButton#obtn_view:disabled {
            background-color: #f5f5f5;
            color: #bdbdbd;
        }

        QTableWidget#otbl_users {
            background-color: #ffffff;
            border: 2px solid #003057;
            border-radius: 10px;
            gridline-color: #dee2e6;
            font-family: 'Poppins', 'Noto Sans Thai';
            font-size: 14px;
            color: #333333;
        }
        QTableWidget#otbl_users::item {
            padding: 8px 12px;
            border-bottom: 1px solid #dee2e6;
        }
        QTableWidget#otbl_users::item:selected {
            background-color: #e3f2fd;
            color: #003057;
            outline: none;
            border: none;
        }
        QTableWidget#otbl_users::item:focus {
            outline: none;
            border: none;
        }
        QTableWidget#otbl_users QHeaderView::section {
            background-color: #003057;
            color: #ffffff;
            font-family: 'Poppins', 'Noto Sans Thai';
            font-size: 14px;
            font-weight: bold;
            padding: 10px 12px;
            border: none;
            border-right: 1px solid #004B93;
        }
        QTableWidget#otbl_users QHeaderView::section:last {
            border-right: none;
        }
        QTableWidget#otbl_users QTableCornerButton::section {
            background-color: #003057;
            border: none;
        }
        QTableWidget#otbl_users QScrollBar:vertical {
            background: #f0f0f0;
            width: 10px;
            border-radius: 5px;
        }
        QTableWidget#otbl_users QScrollBar::handle:vertical {
            background: #003057;
            border-radius: 5px;
            min-height: 30px;
        }
        QTableWidget#otbl_users QScrollBar::add-line:vertical, 
        QTableWidget#otbl_users QScrollBar::sub-line:vertical {
            height: 0px;
        }
   </string>
